#!/usr/bin/env bash
set -euo pipefail

APP_NAME="SushiArrived"
BUNDLE_ID="com.matsushita.AgentSushi"
CONFIG_DIR="$HOME/.sushi-arrived"
HOOK_PATH="$CONFIG_DIR/hook.zsh"
CODEX_CONFIG="$HOME/.codex/config.toml"

usage() {
  cat <<USAGE
Usage:
  agent-sushi activate
  agent-sushi deactivate
USAGE
}

ensure_codex_config() {
  mkdir -p "$(dirname "$CODEX_CONFIG")"
  touch "$CODEX_CONFIG"
}

activate() {
  mkdir -p "$CONFIG_DIR"
  cat > "$HOOK_PATH" <<'HOOK'
# Agent Sushi hook snippet
agent_sushi_notify() {
  mkdir -p "$HOME/.sushi-arrived"
  python3 - <<'PY'
import json
from pathlib import Path

home = Path.home()
codex_dir = home / ".codex"
sessions_root = codex_dir / "sessions"
config = codex_dir / "config.toml"
out = home / ".sushi-arrived" / "current.json"
sessions_dir = home / ".sushi-arrived" / "sessions"
sessions_dir.mkdir(parents=True, exist_ok=True)

title = "タスク"
model = "unknown"
session_id = "unknown"

def latest_rollout_file(root: Path):
    files = list(root.rglob("rollout-*.jsonl"))
    if not files:
        return None
    files.sort(key=lambda p: p.stat().st_mtime, reverse=True)
    return files[0]

rollout = latest_rollout_file(sessions_root)
if rollout and rollout.exists():
    try:
        records = []
        for line in rollout.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
                records.append(obj)
            except Exception:
                pass

        # session id and model from structured events
        for rec in records:
            if rec.get("type") == "session_meta":
                payload = rec.get("payload") or {}
                sid = payload.get("id")
                if sid:
                    session_id = sid

        current_model = None
        for rec in reversed(records):
            if rec.get("type") == "turn_context":
                payload = rec.get("payload") or {}
                m = payload.get("model")
                if m:
                    current_model = m
                    break

        # latest user message from this rollout
        for rec in reversed(records):
            if rec.get("type") == "event_msg":
                payload = rec.get("payload") or {}
                if payload.get("type") == "user_message":
                    text = (payload.get("message") or "").strip()
                    if text:
                        title = text.replace("\n", " ")[:120]
                        break
            if rec.get("type") == "response_item":
                payload = rec.get("payload") or {}
                if payload.get("type") == "message" and payload.get("role") == "user":
                    content = payload.get("content") or []
                    text = ""
                    for c in content:
                        if c.get("type") in ("input_text", "text"):
                            text = (c.get("text") or "").strip()
                            if text:
                                break
                    if text:
                        title = text.replace("\n", " ")[:120]
                        break

        if current_model:
            model = current_model
    except Exception:
        pass

if config.exists():
    try:
        for line in config.read_text(encoding="utf-8").splitlines():
            if line.startswith("model = "):
                model = line.split("=", 1)[1].strip().strip('"')
                break
    except Exception:
        pass

payload = {"title": title, "model": model, "session_id": session_id}
out.write_text(json.dumps(payload, ensure_ascii=False), encoding="utf-8")
(sessions_dir / f"{session_id}.json").write_text(json.dumps(payload, ensure_ascii=False), encoding="utf-8")
PY
  open -a SushiArrived || true
}
HOOK

  ensure_codex_config
  if ! grep -q "agent_sushi_notify" "$CODEX_CONFIG"; then
    cat >> "$CODEX_CONFIG" <<'CFG'

# Agent Sushi
notify = ["zsh", "-lc", "source ~/.sushi-arrived/hook.zsh; agent_sushi_notify"]
CFG
  fi

  # Unsigned local cask builds can be blocked by Gatekeeper as "damaged".
  # Remove quarantine attribute as a pragmatic workaround for local distribution.
  if [ -d "/Applications/SushiArrived.app" ]; then
    xattr -dr com.apple.quarantine "/Applications/SushiArrived.app" 2>/dev/null || true
  fi

  echo "agent-sushi activated"
}

deactivate() {
  rm -f "$HOOK_PATH"
  if [ -f "$CODEX_CONFIG" ]; then
    awk '
      BEGIN { skip=0 }
      /^# Agent Sushi$/ { skip=1; next }
      skip==1 && /^notify = \["zsh", "-lc", "source ~\/\.sushi-arrived\/hook\.zsh; agent_sushi_notify"\]$/ { skip=0; next }
      skip==0 { print }
    ' "$CODEX_CONFIG" > "$CODEX_CONFIG.tmp" && mv "$CODEX_CONFIG.tmp" "$CODEX_CONFIG"
  fi
  echo "agent-sushi deactivated"
}

cmd="${1:-}"
case "$cmd" in
  activate) activate ;;
  deactivate) deactivate ;;
  *) usage; exit 1 ;;
esac
