#!/usr/bin/env bash
set -euo pipefail

APP_NAME="AgentSushi"
BUNDLE_ID="com.matsushita.AgentSushi"
CONFIG_DIR="$HOME/.agent-sushi"
HOOK_PATH="$CONFIG_DIR/hook.zsh"
CODEX_CONFIG="$HOME/.codex/config.toml"
CLAUDE_CONFIG="$HOME/.claude/settings.json"

usage() {
  cat <<USAGE
Usage:
  agent-sushi activate
  agent-sushi deactivate
USAGE
}

ensure_codex_config() {
  mkdir -p "$(dirname "$CODEX_CONFIG")"
  touch "$CODEX_CONFIG"
}

ensure_top_level_notify() {
  local desired='notify = ["zsh", "-lc", "source ~/.agent-sushi/hook.zsh; agent_sushi_notify"]'
  python3 - "$CODEX_CONFIG" "$desired" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
desired = sys.argv[2]
lines = path.read_text(encoding="utf-8").splitlines() if path.exists() else []

# Remove old Agent Sushi/notify variants so we can place a single top-level line.
filtered = []
for line in lines:
    s = line.strip()
    if s == "# Agent Sushi" or s == "[hooks]":
        continue
    if "agent_sushi_notify" in s:
        continue
    filtered.append(line)

# Insert near top-level config area.
insert_idx = 0
for i, line in enumerate(filtered):
    if line.startswith("model_reasoning_effort"):
        insert_idx = i + 1
        break

filtered.insert(insert_idx, desired)
path.write_text("\n".join(filtered) + "\n", encoding="utf-8")
PY
}

ensure_claude_notify() {
  [ -f "$CLAUDE_CONFIG" ] || return 0
  python3 - "$CLAUDE_CONFIG" <<'PY'
from pathlib import Path
import json
import sys

path = Path(sys.argv[1])
notify_cmd = 'zsh -lc "source ~/.agent-sushi/hook.zsh; agent_sushi_notify"'

try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    # Unknown/invalid format: skip safely.
    sys.exit(0)

if not isinstance(data, dict):
    sys.exit(0)

hooks = data.get("hooks")
if hooks is None:
    hooks = {}
    data["hooks"] = hooks
if not isinstance(hooks, dict):
    sys.exit(0)

stop = hooks.get("Stop")
if stop is None:
    stop = []
    hooks["Stop"] = stop
if not isinstance(stop, list):
    sys.exit(0)

entry = {"hooks": [{"type": "command", "command": notify_cmd}]}

def has_notify(items):
    for item in items:
        if not isinstance(item, dict):
            continue
        hs = item.get("hooks")
        if not isinstance(hs, list):
            continue
        for h in hs:
            if isinstance(h, dict) and h.get("type") == "command" and "agent_sushi_notify" in str(h.get("command", "")):
                return True
    return False

if not has_notify(stop):
    stop.append(entry)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
PY
}

remove_claude_notify() {
  [ -f "$CLAUDE_CONFIG" ] || return 0
  python3 - "$CLAUDE_CONFIG" <<'PY'
from pathlib import Path
import json
import sys

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    sys.exit(0)

if not isinstance(data, dict):
    sys.exit(0)
hooks = data.get("hooks")
if not isinstance(hooks, dict):
    sys.exit(0)
stop = hooks.get("Stop")
if not isinstance(stop, list):
    sys.exit(0)

new_stop = []
changed = False
for item in stop:
    if not isinstance(item, dict):
        new_stop.append(item)
        continue
    hs = item.get("hooks")
    if not isinstance(hs, list):
        new_stop.append(item)
        continue
    new_hs = []
    removed = False
    for h in hs:
        if isinstance(h, dict) and h.get("type") == "command" and "agent_sushi_notify" in str(h.get("command", "")):
            removed = True
            changed = True
            continue
        new_hs.append(h)
    if removed:
        if new_hs:
            item = dict(item)
            item["hooks"] = new_hs
            new_stop.append(item)
    else:
        new_stop.append(item)

if changed:
    hooks["Stop"] = new_stop
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
PY
}

activate() {
  mkdir -p "$CONFIG_DIR"
  cat > "$HOOK_PATH" <<'HOOK'
# Agent Sushi hook snippet
agent_sushi_notify() {
  mkdir -p "$HOME/.agent-sushi"
  python3 - <<'PY'
import json
import time
from datetime import datetime, timedelta
from pathlib import Path

home = Path.home()
codex_dir = home / ".codex"
sessions_root = codex_dir / "sessions"
config = codex_dir / "config.toml"
out = home / ".agent-sushi" / "current.json"
sessions_dir = home / ".agent-sushi" / "sessions"
sessions_dir.mkdir(parents=True, exist_ok=True)

title = "タスク"
model = "unknown"
session_id = "unknown"

def read_last_line(path: Path) -> str:
    """Read the last non-empty line of a file efficiently."""
    with path.open("rb") as f:
        f.seek(0, 2)
        pos = f.tell()
        if pos == 0:
            return ""
        buf = b""
        while pos > 0:
            pos -= 1
            f.seek(pos)
            char = f.read(1)
            if char == b"\n" and buf:
                return buf.decode("utf-8").strip()
            buf = char + buf
        return buf.decode("utf-8").strip()

def find_active_rollout(root: Path):
    """Find the rollout file for the most recently completed session."""
    now = datetime.now()

    # Scan today and yesterday directories only (date rollover edge case)
    dirs = []
    for offset in [0, -1]:
        d = now + timedelta(days=offset)
        dir_path = root / str(d.year) / f"{d.month:02d}" / f"{d.day:02d}"
        if dir_path.exists():
            dirs.append(dir_path)

    files = []
    for d in dirs:
        files.extend(d.glob("rollout-*.jsonl"))

    if not files:
        # Fallback: scan all files if no dated dirs found
        files = list(root.rglob("rollout-*.jsonl"))
        if not files:
            return None

    best_file = None
    best_score = 0
    now_ts = time.time()

    for f in files:
        mtime = f.stat().st_mtime

        # Skip files older than 1 hour (not from current batch of sessions)
        if now_ts - mtime > 3600:
            continue

        try:
            last_line = read_last_line(f)
            if not last_line:
                continue
            obj = json.loads(last_line)
            ts_str = obj.get("timestamp", "")
            if not ts_str:
                continue

            dt = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
            ts = dt.timestamp()

            # Prioritize files ending with task_complete event
            is_complete = (
                obj.get("type") == "event_msg"
                and obj.get("payload", {}).get("type") == "task_complete"
            )
            score = ts + (1000000 if is_complete else 0)

            if score > best_score:
                best_score = score
                best_file = f
        except Exception:
            # On parse failure, fall back to mtime
            if mtime > best_score:
                best_score = mtime
                best_file = f

    return best_file

rollout = find_active_rollout(sessions_root)
if rollout and rollout.exists():
    try:
        records = []
        for line in rollout.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
                records.append(obj)
            except Exception:
                pass

        # session id and model from structured events
        for rec in records:
            if rec.get("type") == "session_meta":
                payload = rec.get("payload") or {}
                sid = payload.get("id")
                if sid:
                    session_id = sid

        current_model = None
        for rec in reversed(records):
            if rec.get("type") == "turn_context":
                payload = rec.get("payload") or {}
                m = payload.get("model")
                if m:
                    current_model = m
                    break

        # latest user message from this rollout
        for rec in reversed(records):
            if rec.get("type") == "event_msg":
                payload = rec.get("payload") or {}
                if payload.get("type") == "user_message":
                    text = (payload.get("message") or "").strip()
                    if text:
                        title = text.replace("\n", " ")[:120]
                        break
            if rec.get("type") == "response_item":
                payload = rec.get("payload") or {}
                if payload.get("type") == "message" and payload.get("role") == "user":
                    content = payload.get("content") or []
                    text = ""
                    for c in content:
                        if c.get("type") in ("input_text", "text"):
                            text = (c.get("text") or "").strip()
                            if text:
                                break
                    if text:
                        title = text.replace("\n", " ")[:120]
                        break

        if current_model:
            model = current_model
    except Exception:
        pass

if config.exists():
    try:
        for line in config.read_text(encoding="utf-8").splitlines():
            if line.startswith("model = "):
                model = line.split("=", 1)[1].strip().strip('"')
                break
    except Exception:
        pass

payload = {"title": title, "model": model, "session_id": session_id}
out.write_text(json.dumps(payload, ensure_ascii=False), encoding="utf-8")
(sessions_dir / f"{session_id}.json").write_text(json.dumps(payload, ensure_ascii=False), encoding="utf-8")
PY
  # Best-effort: bring Codex to front first so AgentSushi appears in that context.
  if command -v osascript >/dev/null 2>&1; then
    osascript -e 'tell application "Codex" to activate' >/dev/null 2>&1 || true
  fi
  open -a Codex >/dev/null 2>&1 || true
  sleep 0.15
  # Kill any existing AgentSushi instance first so the new one reads current.json fresh.
  pkill -x AgentSushi 2>/dev/null || true
  sleep 0.05
  open "/Applications/AgentSushi.app" || true
}
HOOK

  ensure_codex_config
  ensure_top_level_notify
  ensure_claude_notify

  # Unsigned local cask builds can be blocked by Gatekeeper as "damaged".
  # Remove quarantine attribute as a pragmatic workaround for local distribution.
  if [ -d "/Applications/AgentSushi.app" ]; then
    xattr -dr com.apple.quarantine "/Applications/AgentSushi.app" 2>/dev/null || true
  fi

  echo "agent-sushi activated"
}

deactivate() {
  rm -f "$HOOK_PATH"
  if [ -f "$CODEX_CONFIG" ]; then
    python3 - "$CODEX_CONFIG" <<'PY'
from pathlib import Path
import sys
path = Path(sys.argv[1])
lines = path.read_text(encoding="utf-8").splitlines()
out = []
for line in lines:
    s = line.strip()
    if s == "# Agent Sushi" or s == "[hooks]":
        continue
    if "agent_sushi_notify" in s:
        continue
    out.append(line)
path.write_text("\n".join(out) + "\n", encoding="utf-8")
PY
  fi
  remove_claude_notify
  echo "agent-sushi deactivated"
}

cmd="${1:-}"
case "$cmd" in
  activate) activate ;;
  deactivate) deactivate ;;
  *) usage; exit 1 ;;
esac
